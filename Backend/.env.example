# Copy this file to .env and fill values for local development
# MONGO_URI should point to your MongoDB server. Example for MongoDB Atlas:
# Replace <username>, <password>, and <cluster> with your values.
MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/planora_db?retryWrites=true&w=majority
# Change the JWT secret for development (keep a strong secret in production):
JWT_SECRET_KEY=your_jwt_secret_here
